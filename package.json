{
  "name": "yolo",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "vite --host",
    "dev:build": "vite build && vite",
    "build": "tsc && vite build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npx oxlint src electron shared server",
    "lint:fix": "npx oxlint --fix src electron shared server",
    "format": "npx oxfmt --check src electron shared server",
    "format:fix": "npx oxfmt --write src electron shared server",
    "typecheck": "tsc --noEmit",
    "validate": "npm run lint && npm run typecheck && npm run test",
    "preview": "vite preview",
    "postinstall": "node node_modules/electron/install.js && electron-builder install-app-deps",
    "version:patch": "pnpm version patch --no-git-tag-version",
    "version:minor": "pnpm version minor --no-git-tag-version",
    "version:major": "pnpm version major --no-git-tag-version",
    "release:tag": "node scripts/tag-release.mjs"
  },
